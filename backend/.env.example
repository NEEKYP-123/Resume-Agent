# Admin login for the dashboard
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
JWT_SECRET=replace-with-a-long-random-string
FRONTEND_URL=http://localhost:5501

# Gmail API (OAuth 2.0) - see gmail_service.py docstring for how to get these
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_LABEL_FILTER=Resumes

# MongoDB Atlas - leave blank while LOCAL_MODE=true
MONGODB_URI=
MONGODB_DB_NAME=resume_agent
MONGODB_COLLECTION_NAME=resumes

# Backblaze B2 (S3-compatible) - leave blank while LOCAL_MODE=true
B2_ENDPOINT=
B2_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET_NAME=resume-agent-files

# Gemini - server-side default key (users can override with their own in the UI)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Set to false once you've wired up real MongoDB/B2 credentials
LOCAL_MODE=true
